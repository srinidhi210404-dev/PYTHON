import math
a=int(input("Enter the co-efficient of x*x"))
b=int(input("Enter the co-efficient of x"))
c=int(input("Enter the constant value"))
q=(b*b)-(4*a*c)
if(q==0):
e=-b/(2*a)
print"The roots are real and equal",e
elif(q>0):
f=(-b+math.sqrt(q))/(2*a)
g=(-b-math.sqrt(q))/(2*a)
print"Roots are real and distinct",f,g
else:
h=-b/(2*a)
i=math.sqrt(-q)/(2*a)
print"Complex roots"
print h,"+j",i
print h,"-j",i
